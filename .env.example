# Copy to .env and fill in. All values below are examples, not real keys.

# --- Supabase (required) ---
# Project URL and publishable (anon) key: Supabase dashboard → Settings → API.
# For local dev with `supabase start`, use the values it prints.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# --- Market data (optional — price lookups degrade gracefully without them) ---
# TwelveData (stocks/ETF prices + instrument lookup): https://twelvedata.com
# Server-side only; do NOT prefix with NEXT_PUBLIC_.
TWELVEDATA_API_KEY=

# CoinGecko demo key (crypto prices): https://www.coingecko.com/en/api
# Used from the browser, hence NEXT_PUBLIC_ (demo tier, low blast radius).
NEXT_PUBLIC_COINGECKO_API_KEY=
